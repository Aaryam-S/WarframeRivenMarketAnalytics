rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: weapon_activity
    // Document ID: {weaponId}_{date}
    // Fields:
    //   - weaponId: string (required) - url_name of the weapon
    //   - weaponName: string (required) - display name
    //   - date: string (required) - YYYY-MM-DD
    //   - bidCount: int (required) - count of auctions with bids
    //   - listingCount: int (required) - total auctions
    //   - lastUpdated: timestamp (required) - update time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aaryamsharma3@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['weaponId', 'weaponName', 'date', 'bidCount', 'listingCount', 'lastUpdated']) &&
             data.weaponId is string &&
             data.weaponName is string &&
             data.date is string &&
             data.bidCount is int &&
             data.listingCount is int;
    }

    match /weapon_activity/{activityId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidActivity(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
